{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "victus-deck",
  "version": "0.1.0",
  "identifier": "com.dhruvil.victus-deck",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/victus-deck/browser"
  },
  "app": {
    "windows": [
      {
        "title": "victus-deck",
        "width": 800,
        "height": 600,
        "backgroundColor": "#0d0f14"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}