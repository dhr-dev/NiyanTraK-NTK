{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NiyanTraK",
  "version": "4.0.0",
  "identifier": "com.dhrdev.niyantrak",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/niyantrak/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NiyanTraK",
        "width": 800,
        "height": 600,
        "minWidth": 450,
        "minHeight": 450,
        "visible": false,
        "backgroundColor": "#0d0f14"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/ryzenadj-win64/*",
      "resources/OmenHwCtl.ps1"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./hooks.nsh"
      }
    }
  }
}