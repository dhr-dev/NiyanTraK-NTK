{
    // =========================
    // FONT (Editor / Code)
    // =========================
    "editor.fontFamily": "JetBrains Mono, Fira Code, Cascadia Code, monospace",
    "editor.fontSize": 15,
    "editor.lineHeight": 22,
    "editor.fontLigatures": true,
    "editor.fontWeight": "400",
    "editor.letterSpacing": 0.3,
    // =========================
    // UI SCALE (Whole IDE)
    // =========================
    "window.zoomLevel": 0.4,
    "workbench.list.automaticKeyboardNavigation": true,
    // =========================
    // SIDEBAR / EXPLORER / AGENT PANEL
    // (this affects left + right panels)
    // =========================
    "workbench.sideBar.location": "left",
    "workbench.tree.indent": 16,
    "workbench.iconTheme": "vs-seti",
    // Make sidebar text more readable
    "workbench.list.defaultFindMatchType": "fuzzy",
    "workbench.list.smoothScrolling": true,
    // =========================
    // CHAT / AGENT PANEL (if supported)
    // =========================
    "chat.fontSize": 14,
    "chat.lineHeight": 1.5,
    // Some VS Code forks use this for agent/chat UI scaling
    "accessibility.fontSize": 14,
    // =========================
    // TERMINAL (optional but useful)
    // =========================
    "terminal.integrated.fontFamily": "JetBrains Mono, monospace",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.lineHeight": 1.2,
    // =========================
    // RENDERING QUALITY (helps eyes)
    // =========================
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.minimap.enabled": false,
    // =========================
    // SCROLL / ZOOM BEHAVIOR
    // =========================
    "editor.mouseWheelZoom": true
}